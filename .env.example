# Email (submission + contact forms)
SUBMISSION_EMAIL=your-inbox@example.com
GMAIL_USER=your-inbox@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Optional — not used by current submission route
RESEND_API_KEY=

# Supabase — Settings → API in dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to browser; not required for auth/submissions today
SUPABASE_SERVICE_ROLE_KEY=
